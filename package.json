{
	"name": "crust",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"build:docs": "turbo run build --filter='./apps/docs'",
		"build:packages": "turbo run build --filter='./packages/*'",
		"dev:docs": "turbo run dev --filter='./apps/docs'",
		"check": "biome check",
		"check:types": "turbo run check:types",
		"test": "turbo run test",
		"changeset": "changeset",
		"packages:version": "changeset version && bun update",
		"packages:publish": "bun ./scripts/publish-packages.mjs"
	},
	"devDependencies": {
		"@changesets/cli": "^2.30.0",
		"@biomejs/biome": "2.4.8",
		"@types/bun": "^1.3.11",
		"turbo": "^2.8.20",
		"typescript": "5.9.3"
	},
	"catalog": {
		"bunup": "^0.16.31",
		"typescript": "^5"
	},
	"engines": {
		"node": ">=18"
	},
	"packageManager": "bun@1.3.10",
	"workspaces": [
		"apps/*",
		"packages/*"
	]
}
