{
	"name": "{{name}}",
	"version": "0.0.0",
	"type": "module",
	"description": "A CLI built with Crust",
	"files": [
		"dist/cli",
		"dist/cli.cmd",
		"dist/*-bun-*"
	],
	"bin": {
		"{{name}}": "dist/cli"
	},
	"scripts": {
		"dev": "bun run src/cli.ts",
		"build": "node ./node_modules/@crustjs/crust/bin/crust.js build",
		"package": "node ./node_modules/@crustjs/crust/bin/crust.js build --package",
		"publish": "node ./node_modules/@crustjs/crust/bin/crust.js publish --stage-dir dist/npm",
		"start": "./dist/cli",
		"check:types": "tsc --noEmit"
	},
	"devDependencies": {
		"@crustjs/core": "latest",
		"@crustjs/crust": "latest",
		"@crustjs/plugins": "latest",
		"@types/bun": "latest",
		"typescript": "^5"
	}
}
