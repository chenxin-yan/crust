{
	"name": "{{name}}",
	"version": "0.0.0",
	"type": "module",
	"description": "A CLI built with Crust",
	"files": [
		"dist"
	],
	"bin": {
		"{{name}}": "dist/cli"
	},
	"scripts": {
		"dev": "bun run src/cli.ts",
		"build": "crust build",
		"start": "./dist/cli",
		"check:types": "tsc --noEmit"
	},
	"dependencies": {
		"@crustjs/core": "latest",
		"@crustjs/plugins": "latest"
	},
	"devDependencies": {
		"@crustjs/crust": "latest",
		"@types/bun": "latest",
		"typescript": "^5"
	}
}
