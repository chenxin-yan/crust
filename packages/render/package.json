{
	"name": "@crustjs/render",
	"version": "0.0.1",
	"description": "Terminal rendering for the Crust CLI ecosystem",
	"type": "module",
	"license": "MIT",
	"author": "chenxin-yan",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/chenxin-yan/crust.git",
		"directory": "packages/render"
	},
	"homepage": "https://crustjs.com",
	"bugs": {
		"url": "https://github.com/chenxin-yan/crust/issues"
	},
	"keywords": [
		"cli",
		"markdown",
		"render",
		"terminal",
		"bun",
		"typescript"
	],
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "bunup",
		"dev": "bunup --watch",
		"check:types": "tsc --noEmit",
		"test": "bun test"
	},
	"devDependencies": {
		"@crustjs/config": "workspace:*",
		"@types/mdast": "^4.0.4",
		"bunup": "catalog:"
	},
	"peerDependencies": {
		"typescript": "catalog:"
	},
	"dependencies": {
		"@crustjs/style": "workspace:*",
		"mdast-util-from-markdown": "^2.0.3",
		"mdast-util-gfm": "^3.1.0",
		"micromark-extension-gfm": "^3.0.0"
	}
}
